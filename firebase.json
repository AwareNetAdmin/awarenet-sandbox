{
  "hosting": [
    {
      "target": "sandbox",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "*.md",
        "build-search-index.js",
        "deploy.sh",
        "deploy-production.sh",
        "service-account-key.json"
      ],
      "redirects": [
        {
          "source": "/configuration-notes/false-alerts",
          "destination": "/false-alerts",
          "type": 301
        }
      ],
      "headers": [
        {
          "source": "**/*.@(jpg|jpeg|gif|png|svg|webp)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=7200"
            }
          ]
        },
        {
          "source": "**/*.@(js|json)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=3600"
            }
          ]
        }
      ],
      "cleanUrls": true,
      "trailingSlash": false
    },
    {
      "target": "production",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "*.md",
        "build-search-index.js",
        "deploy.sh",
        "deploy-production.sh",
        "service-account-key.json"
      ],
      "redirects": [
        {
          "source": "/configuration-notes/false-alerts",
          "destination": "/false-alerts",
          "type": 301
        }
      ],
      "headers": [
        {
          "source": "**/*.@(jpg|jpeg|gif|png|svg|webp)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=7200"
            }
          ]
        },
        {
          "source": "**/*.@(js|json)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=3600"
            }
          ]
        }
      ],
      "cleanUrls": true,
      "trailingSlash": false
    }
  ]
}
